{
  xdg.configFile."fuzzel/fuzzel.ini".text = ''
    [main]
    font=JetBrainsMono Nerd Font Mono:size=13
    icon-theme=Papirus-Dark
    icons-enabled=yes
    terminal=kitty
    layer=overlay
    width=35
    lines=8
    horizontal-pad=20
    vertical-pad=12
    inner-pad=8

    [colors]
    background=16161dff
    text=dcd7baff
    match=7e9cd8ff
    selection=2a2a37ff
    selection-text=dcd7baff
    selection-match=7e9cd8ff
    border=363646ff

    [border]
    width=2
    radius=4

    [dmenu]
    exit-immediately-if-empty=yes
  '';
}
